{
  "name": "obsidian-folder-sort-newest",
  "version": "0.0.1",
  "description": "Spike plugin for Z-to-A folder ordering in Obsidian's native File Explorer.",
  "license": "MIT",
  "author": "Viggo Meesters",
  "type": "module",
  "scripts": {
    "build": "NODE_ENV=production node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs",
    "lint": "node scripts/lint.mjs",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node scripts/smoke.mjs",
    "sync:test-vault": "npm run build && node scripts/sync-test-vault.mjs",
    "smoke:cdp": "node scripts/smoke-cdp.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "esbuild": "^0.25.12",
    "obsidian": "^1.8.7",
    "typescript": "^5.9.3"
  }
}
